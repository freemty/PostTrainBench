Bootstrap: docker
From: nvidia/cuda:12.9.1-cudnn-devel-ubuntu22.04

%files
    containers/requirements-direct.txt /opt/requirements-direct.txt

%post
    chmod 1777 /tmp
    export DEBIAN_FRONTEND=noninteractive

    # --- CN network adaptation: apt mirror ---
    # apt-get update may return 0 even if Ubuntu sources fail (CUDA repo succeeds).
    # Check for actual errors in output to detect unreachable Ubuntu mirrors.
    APT_LOG=$(apt-get update -o Acquire::http::Timeout=10 2>&1) || true
    if echo "$APT_LOG" | grep -q "Err:.*archive.ubuntu.com\|Err:.*security.ubuntu.com\|Unable to connect\|connection timed out"; then
        echo ">>> Ubuntu apt sources unreachable, switching to aliyun mirror"
        sed -i 's|http://archive.ubuntu.com|http://mirrors.aliyun.com|g' /etc/apt/sources.list
        sed -i 's|http://security.ubuntu.com|http://mirrors.aliyun.com|g' /etc/apt/sources.list
        # Also handle DEB822 format (Ubuntu 24.04+)
        if [ -f /etc/apt/sources.list.d/ubuntu.sources ]; then
            sed -i 's|http://archive.ubuntu.com|http://mirrors.aliyun.com|g' /etc/apt/sources.list.d/ubuntu.sources
            sed -i 's|http://security.ubuntu.com|http://mirrors.aliyun.com|g' /etc/apt/sources.list.d/ubuntu.sources
        fi
        apt-get update
    else
        echo ">>> Ubuntu apt sources reachable"
    fi

    apt-get install -y \
        python3.10 \
        python3-dev \
        git \
        wget \
        curl \
        build-essential \
        && rm -rf /var/lib/apt/lists/*

    # Create python3 symlink
    ln -sf /usr/bin/python3.10 /usr/bin/python3
    ln -sf /usr/bin/python3.10 /usr/bin/python

    # Remove PEP 668 restriction (if present)
    rm -f /usr/lib/python3.*/EXTERNALLY-MANAGED

    # Install Node.js (LTS version 22.x) for npm
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
    apt-get install -y nodejs

    # Install uv
    curl -LsSf https://astral.sh/uv/install.sh | sh
    export PATH="/root/.local/bin:$PATH"

    # --- CN network adaptation: pip mirror ---
    # Test pypi.org speed; if slow, use aliyun mirror for all uv commands
    PYPI_SPEED=$(curl -m 5 -s -o /dev/null -w '%{speed_download}' https://pypi.org/simple/pip/ 2>/dev/null || echo "0")
    if python3 -c "exit(0 if float('$PYPI_SPEED') > 50000 else 1)" 2>/dev/null; then
        echo ">>> pypi.org reachable (${PYPI_SPEED} B/s), using default"
    else
        echo ">>> pypi.org slow/unreachable, switching to aliyun mirror"
        export UV_INDEX_URL="https://mirrors.aliyun.com/pypi/simple/"
    fi

    uv pip install --system --no-cache vllm==0.11.0 --torch-backend=auto

    # Pinned direct dependencies (MUST use requirements-direct.txt to lock versions)
    uv pip install --system --no-cache -r /opt/requirements-direct.txt

    # flash-attn (needs no-build-isolation)
    uv pip install --system --no-cache flash-attn==2.8.3 --no-build-isolation

    # Install AI CLI tools via npm
    npm install -g \
        @anthropic-ai/claude-code@2.0.55 \
        @openai/codex@0.79.0 \
        @google/gemini-cli@0.18.4

    # install inspect evals (pinned commit for reproducibility)
    mkdir -p /opt
    cd /opt
    git clone https://github.com/UKGovernmentBEIS/inspect_evals.git
    cd /opt/inspect_evals
    git checkout 06001a83e6d7c709c2ede0570dce7f1031a0bad8
    uv pip install --system --no-cache .

%environment
    export PATH="/root/.local/bin:$PATH"
    export NO_PROXY="localhost,127.0.0.1"
    export no_proxy="localhost,127.0.0.1"

%runscript
    exec python3 "$@"

%labels
    Version v1.2
    Description Python ML container with CUDA support for transformers and LLM training (using uv) + AI CLI tools

%help
    Note: Use the --nv flag to enable NVIDIA GPU support when running the container.
    CN network: apt/pip mirrors auto-detected. Use docker-daemon bootstrap if Docker Hub blocked.
